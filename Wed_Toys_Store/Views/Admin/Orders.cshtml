@model Wed_Toys_Store.Models.OrdersViewModel

@{
    ViewData["Title"] = "Orders Management";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" />
    <style>
        :root {
            --admin-sidebar-bg: #4169E1;
            --admin-sidebar-hover: #3556C7;
            --admin-sidebar-active: #2E4FC0;
            --admin-sidebar-header: #2E4FC0;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f5f5f5;
        }

        .admin-sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            width: 250px;
            background-color: var(--admin-sidebar-bg);
            color: white;
            padding: 0;
            overflow-y: auto;
            z-index: 1000;
        }

        .admin-sidebar .sidebar-header {
            padding: 20px;
            background-color: var(--admin-sidebar-header);
            border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        }

        .admin-sidebar .sidebar-header h4 {
            margin: 0;
            color: white;
        }

        .admin-sidebar .menu-section {
            padding: 15px 0;
        }

        .admin-sidebar .menu-section-title {
            padding: 10px 20px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: rgba(255, 255, 255, 0.5);
            font-weight: 600;
        }

        .admin-sidebar .menu-item {
            padding: 12px 20px;
            color: rgba(255, 255, 255, 0.8);
            text-decoration: none;
            display: block;
            transition: all 0.3s;
            border-left: 3px solid transparent;
        }

        .admin-sidebar .menu-item:hover {
            background-color: var(--admin-sidebar-hover);
            color: white;
            border-left-color: var(--admin-sidebar-active);
        }

        .admin-sidebar .menu-item.active {
            background-color: var(--admin-sidebar-active);
            color: white;
            border-left-color: white;
        }

        .admin-sidebar .menu-item i {
            width: 20px;
            margin-right: 10px;
        }

        .admin-sidebar .sidebar-footer {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 15px 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.2);
            background-color: var(--admin-sidebar-header);
        }

        .admin-sidebar .sidebar-footer .btn {
            width: 100%;
            margin-bottom: 10px;
        }

        .admin-sidebar .sidebar-footer .btn:last-child {
            margin-bottom: 0;
        }

        .admin-main {
            margin-left: 250px;
            min-height: 100vh;
        }

        .admin-content {
            padding: 2rem;
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    @await Html.PartialAsync("_AdminSidebar")

    <!-- Main Content -->
    <div class="admin-main">
        <div class="admin-content">
            <!-- Title -->
            <div class="mb-4">
                <h2 class="mb-0">
                    <i class="bi bi-cart-check me-2"></i>Orders Management
                </h2>
            </div>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- Search and Filter Section -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label small text-muted">Enter search keyword</label>
                            <div class="input-group">
                                <input type="text" class="form-control" placeholder="Enter order ID or customer name">
                                <button class="btn btn-primary" type="button">
                                    <i class="bi bi-search me-1"></i>Search
                                </button>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <label for="pageSizeSelect" class="form-label small text-muted">Items per page</label>
                            <select class="form-select" id="pageSizeSelect" name="pageSize" aria-label="Select number of items per page" onchange="changePageSize(this.value)">
                                <option value="10" selected="@(Model.PageSize == 10)">10</option>
                                <option value="20" selected="@(Model.PageSize == 20)">20</option>
                                <option value="50" selected="@(Model.PageSize == 50)">50</option>
                                <option value="100" selected="@(Model.PageSize == 100)">100</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="statusFilter" class="form-label small text-muted">Filter by Status</label>
                            <select class="form-select" id="statusFilter" onchange="filterByStatus(this.value)">
                                @{
                                    var currentStatus = ViewBag.CurrentStatus as string ?? "";
                                }
                                @if (string.IsNullOrEmpty(currentStatus))
                                {
                                    <option value="" selected>All Statuses</option>
                                }
                                else
                                {
                                    <option value="">All Statuses</option>
                                }
                                @if (currentStatus == "Pending")
                                {
                                    <option value="Pending" selected>Pending</option>
                                }
                                else
                                {
                                    <option value="Pending">Pending</option>
                                }
                                @if (currentStatus == "Processing")
                                {
                                    <option value="Processing" selected>Processing</option>
                                }
                                else
                                {
                                    <option value="Processing">Processing</option>
                                }
                                @if (currentStatus == "Shipped")
                                {
                                    <option value="Shipped" selected>Shipped</option>
                                }
                                else
                                {
                                    <option value="Shipped">Shipped</option>
                                }
                                @if (currentStatus == "Delivered")
                                {
                                    <option value="Delivered" selected>Delivered</option>
                                }
                                else
                                {
                                    <option value="Delivered">Delivered</option>
                                }
                                @if (currentStatus == "Cancelled")
                                {
                                    <option value="Cancelled" selected>Cancelled</option>
                                }
                                else
                                {
                                    <option value="Cancelled">Cancelled</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse">
                                Add filter conditions
                            </button>
                        </div>
                    </div>
                    
                    <div class="collapse mt-3" id="filterCollapse">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label small">Date From</label>
                                <input type="date" class="form-control" id="dateFrom">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Date To</label>
                                <input type="date" class="form-control" id="dateTo">
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <button class="btn btn-primary w-100">
                                    <i class="bi bi-funnel me-2"></i>Filter
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Orders Table -->
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Order Date</th>
                                <th>Total Amount</th>
                                <th>Status</th>
                                <th>Shipping Address</th>
                                <th class="w-auto">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Orders != null && Model.Orders.Any())
                            {
                                @foreach (var order in Model.Orders)
                                {
                                    <tr>
                                        <td><strong>#@order.Id</strong></td>
                                        <td>
                                            <div class="fw-semibold">@(order.User?.Email ?? "N/A")</div>
                                            @if (order.User != null)
                                            {
                                                <small class="text-muted">@order.UserId</small>
                                            }
                                        </td>
                                        <td>
                                            <small>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</small>
                                        </td>
                                        <td>
                                            <strong class="text-primary">@order.OrderItems.Sum(item => item.Quantity * item.Price).ToString("N0")₫</strong>
                                        </td>
                                        <td>
                                            @{
                                                var statusClass = order.Status switch
                                                {
                                                    "Pending" => "bg-warning",
                                                    "Processing" => "bg-info",
                                                    "Shipped" => "bg-primary",
                                                    "Delivered" => "bg-success",
                                                    "Cancelled" => "bg-danger",
                                                    _ => "bg-secondary"
                                                };
                                            }
                                            <span class="badge @statusClass">@order.Status</span>
                                        </td>
                                        <td>
                                            <small class="text-muted">@(order.ShippingAddress.Length > 30 ? order.ShippingAddress.Substring(0, 30) + "..." : order.ShippingAddress)</small>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                <a href="@Url.Action("OrderDetails", "Admin", new { id = order.Id })" class="btn btn-outline-primary" title="View Details">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                @{
                                                    var isFinalized = order.Status == "Cancelled" || order.Status == "Delivered";
                                                }
                                                @if (!isFinalized)
                                                {
                                                    <div class="btn-group btn-group-sm">
                                                        <button type="button" class="btn btn-outline-secondary dropdown-toggle" 
                                                                data-bs-toggle="dropdown" 
                                                                aria-expanded="false">
                                                            <i class="bi bi-gear"></i>
                                                        </button>
                                                        <ul class="dropdown-menu">
                                                            <li><a class="dropdown-item" href="#" onclick="updateStatus(@order.Id, 'Pending'); return false;">Pending</a></li>
                                                            <li><a class="dropdown-item" href="#" onclick="updateStatus(@order.Id, 'Processing'); return false;">Processing</a></li>
                                                            <li><a class="dropdown-item" href="#" onclick="updateStatus(@order.Id, 'Shipped'); return false;">Shipped</a></li>
                                                            <li><a class="dropdown-item" href="#" onclick="updateStatus(@order.Id, 'Delivered'); return false;">Delivered</a></li>
                                                            <li><hr class="dropdown-divider"></li>
                                                            <li><a class="dropdown-item text-danger" href="#" onclick="updateStatus(@order.Id, 'Cancelled'); return false;">Cancelled</a></li>
                                                        </ul>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <button type="button" class="btn btn-outline-secondary" disabled title="Status cannot be changed">
                                                        <i class="bi bi-gear"></i>
                                                    </button>
                                                }
                                                @if (!isFinalized)
                                                {
                                                    <button type="button" class="btn btn-outline-success" onclick="completeOrder(@order.Id)" title="Complete Order">
                                                        <i class="bi bi-check-circle"></i>
                                                    </button>
                                                    <button type="button" class="btn btn-outline-danger" onclick="cancelOrder(@order.Id)" title="Cancel Order">
                                                        <i class="bi bi-x-lg"></i>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-5 text-muted">
                                        <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                                        No orders found
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Pagination -->
            @if (Model != null && Model.Orders != null && Model.Orders.Any() && Model.TotalPages > 1)
            {
                <nav aria-label="Page navigation" class="mt-4">
                    <ul class="pagination justify-content-center mb-0">
                                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                            <a class="page-link" 
                               href="@(Model.HasPreviousPage ? Url.Action("Orders", "Admin", new { page = Model.CurrentPage - 1, pageSize = Model.PageSize, status = ViewBag.CurrentStatus }) : "#")"
                               aria-label="Previous"
                               @(Model.HasPreviousPage ? "" : "aria-disabled=\"true\" tabindex=\"-1\"")>
                                <span aria-hidden="true">Previous</span>
                            </a>
                        </li>
                        @{
                            int startPage = Math.Max(1, Model.CurrentPage - 2);
                            int endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 2);
                            
                            if (startPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Orders", "Admin", new { page = 1, pageSize = Model.PageSize, status = ViewBag.CurrentStatus })" aria-label="Go to page 1">1</a>
                                </li>
                                @if (startPage > 2)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link" aria-hidden="true">...</span>
                                    </li>
                                }
                            }
                            
                            for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    @if (i == Model.CurrentPage)
                                    {
                                        <a class="page-link" 
                                           href="@Url.Action("Orders", "Admin", new { page = i, pageSize = Model.PageSize, status = ViewBag.CurrentStatus })"
                                           aria-label="Go to page @i"
                                           aria-current="page">@i</a>
                                    }
                                    else
                                    {
                                        <a class="page-link" 
                                           href="@Url.Action("Orders", "Admin", new { page = i, pageSize = Model.PageSize, status = ViewBag.CurrentStatus })"
                                           aria-label="Go to page @i">@i</a>
                                    }
                                </li>
                            }
                            
                            if (endPage < Model.TotalPages)
                            {
                                @if (endPage < Model.TotalPages - 1)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link" aria-hidden="true">...</span>
                                    </li>
                                }
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Orders", "Admin", new { page = Model.TotalPages, pageSize = Model.PageSize, status = ViewBag.CurrentStatus })" aria-label="Go to page @Model.TotalPages">@Model.TotalPages</a>
                                </li>
                            }
                        }
                        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                            <a class="page-link" 
                               href="@(Model.HasNextPage ? Url.Action("Orders", "Admin", new { page = Model.CurrentPage + 1, pageSize = Model.PageSize, status = ViewBag.CurrentStatus }) : "#")" 
                               aria-label="Next"
                               @(Model.HasNextPage ? "" : "aria-disabled=\"true\" tabindex=\"-1\"")>
                                <span aria-hidden="true">Next</span>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>

    <!-- Hidden form for AntiForgeryToken -->
    <form id="antiForgeryForm" style="display: none;">
        @Html.AntiForgeryToken()
    </form>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function changePageSize(pageSize) {
            window.location.href = '@Url.Action("Orders", "Admin")?page=1&pageSize=' + pageSize;
        }

        function filterByStatus(status) {
            const url = new URL(window.location.href);
            url.searchParams.delete('status');
            url.searchParams.delete('page');
            if (status) {
                url.searchParams.set('status', status);
            }
            url.searchParams.set('page', '1');
            window.location.href = url.toString();
        }

        function updateStatus(orderId, status) {
            if (confirm('Are you sure you want to update the order status to "' + status + '"?')) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '@Url.Action("UpdateOrderStatus", "Admin")';
                
                const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]');
                if (token) {
                    const tokenInput = document.createElement('input');
                    tokenInput.type = 'hidden';
                    tokenInput.name = '__RequestVerificationToken';
                    tokenInput.value = token.value;
                    form.appendChild(tokenInput);
                }
                
                const idInput = document.createElement('input');
                idInput.type = 'hidden';
                idInput.name = 'id';
                idInput.value = orderId;
                form.appendChild(idInput);
                
                const statusInput = document.createElement('input');
                statusInput.type = 'hidden';
                statusInput.name = 'status';
                statusInput.value = status;
                form.appendChild(statusInput);
                
                document.body.appendChild(form);
                form.submit();
            }
        }

        function cancelOrder(orderId) {
            if (confirm('Are you sure you want to cancel this order?')) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '@Url.Action("CancelOrder", "Admin")';
                
                const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]');
                if (token) {
                    const tokenInput = document.createElement('input');
                    tokenInput.type = 'hidden';
                    tokenInput.name = '__RequestVerificationToken';
                    tokenInput.value = token.value;
                    form.appendChild(tokenInput);
                }
                
                const idInput = document.createElement('input');
                idInput.type = 'hidden';
                idInput.name = 'id';
                idInput.value = orderId;
                form.appendChild(idInput);
                
                document.body.appendChild(form);
                form.submit();
            }
        }

        function completeOrder(orderId) {
            if (confirm('Are you sure you want to mark this order as delivered (completed)?')) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '@Url.Action("CompleteOrder", "Admin")';
                
                const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]');
                if (token) {
                    const tokenInput = document.createElement('input');
                    tokenInput.type = 'hidden';
                    tokenInput.name = '__RequestVerificationToken';
                    tokenInput.value = token.value;
                    form.appendChild(tokenInput);
                }
                
                const idInput = document.createElement('input');
                idInput.type = 'hidden';
                idInput.name = 'id';
                idInput.value = orderId;
                form.appendChild(idInput);
                
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
</body>
</html>

