@{
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}

<div class="admin-sidebar">
    <div class="sidebar-header">
        <h4><i class="bi bi-speedometer2 me-2"></i>Admin Panel</h4>
    </div>
    
    <div class="menu-section pb-5 mb-5">
        <div class="menu-section-title">Menu Main</div>
        <a href="@Url.Action("Dashboard", "Admin")" class="menu-item @(currentController == "Admin" && currentAction == "Dashboard" ? "active" : "")">
            <i class="bi bi-house-door"></i> Dashboard
        </a>
        <a href="@Url.Action("Products", "Admin")" class="menu-item @(currentController == "Admin" && currentAction == "Products" ? "active" : "")">
            <i class="bi bi-box-seam"></i> Products
        </a>
        <a href="@Url.Action("Index", "Banners")" class="menu-item @(currentController == "Banners" ? "active" : "")">
            <i class="bi bi-image"></i> Banners
        </a>
        <a href="@Url.Action("Index", "Brands")" class="menu-item @(currentController == "Brands" ? "active" : "")">
            <i class="bi bi-tags"></i> Brands
        </a>
        <a href="@Url.Action("Orders", "Admin")" class="menu-item @(currentController == "Admin" && currentAction == "Orders" ? "active" : "")">
            <i class="bi bi-cart-check"></i> Orders
        </a>
        <a href="#" class="menu-item">
            <i class="bi bi-chat-left-text"></i> Comments
        </a>
        <a href="@Url.Action("Users", "Admin")" class="menu-item @(currentController == "Admin" && currentAction == "Users" ? "active" : "")">
            <i class="bi bi-people"></i> Members
        </a>
    </div>
    
    <!-- Sidebar Footer with Logout and Back to Website -->
    <div class="sidebar-footer">
        <a href="@Url.Action("Index", "Home")" class="btn btn-outline-light btn-sm">
            <i class="bi bi-arrow-left me-2"></i>Back to Website
        </a>
        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-light btn-sm w-100">
                <i class="bi bi-box-arrow-right me-2"></i>Logout
            </button>
        </form>
    </div>
</div>


