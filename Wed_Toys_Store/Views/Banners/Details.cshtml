@model Wed_Toys_Store.Models.Banner

@{
    ViewData["Title"] = "Banner Details";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" />
    <style>
        :root {
            --admin-sidebar-bg: #4169E1;
            --admin-sidebar-hover: #3556C7;
            --admin-sidebar-active: #2E4FC0;
            --admin-sidebar-header: #2E4FC0;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f5f5f5;
        }

        .admin-sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            width: 250px;
            background-color: var(--admin-sidebar-bg);
            color: white;
            padding: 0;
            overflow-y: auto;
            z-index: 1000;
        }

        .admin-sidebar .sidebar-header {
            padding: 20px;
            background-color: var(--admin-sidebar-header);
            border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        }

        .admin-sidebar .sidebar-header h4 {
            margin: 0;
            font-weight: bold;
            color: white;
        }

        .admin-sidebar .menu-section {
            padding: 15px 0;
        }

        .admin-sidebar .menu-section-title {
            padding: 10px 20px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: rgba(255, 255, 255, 0.5);
            font-weight: 600;
        }

        .admin-sidebar .menu-item {
            padding: 12px 20px;
            color: rgba(255, 255, 255, 0.8);
            text-decoration: none;
            display: block;
            transition: all 0.3s;
            border-left: 3px solid transparent;
        }

        .admin-sidebar .menu-item:hover {
            background-color: var(--admin-sidebar-hover);
            color: white;
            border-left-color: var(--admin-sidebar-active);
        }

        .admin-sidebar .menu-item.active {
            background-color: var(--admin-sidebar-active);
            color: white;
            border-left-color: white;
        }

        .admin-sidebar .menu-item i {
            width: 20px;
            margin-right: 10px;
        }

        .admin-sidebar .sidebar-footer {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 15px 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.2);
            background-color: var(--admin-sidebar-header);
        }

        .admin-sidebar .sidebar-footer .btn {
            width: 100%;
            margin-bottom: 10px;
        }

        .admin-sidebar .sidebar-footer .btn:last-child {
            margin-bottom: 0;
        }

        .admin-main {
            margin-left: 250px;
            min-height: 100vh;
        }

        .admin-content {
            padding: 2rem;
        }

        .banner-preview {
            max-width: 100%;
            max-height: 400px;
            object-fit: cover;
        }
    </style>
</head>
<body>
    @await Html.PartialAsync("_AdminSidebar")

    <!-- Main Content -->
    <div class="admin-main">
        <div class="admin-content">
            <div class="card shadow-sm">
                <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="mb-0">
                        <i class="bi bi-eye me-2"></i>Banner Details
                    </h2>
                    <div class="d-flex gap-2">
                        <a href="@Url.Action("Edit", "Banners", new { id = Model.Id })" class="btn btn-warning">
                            <i class="bi bi-pencil me-2"></i>Edit
                        </a>
                        <a href="@Url.Action("Index", "Banners")" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Back to List
                        </a>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-8">
                        <div class="py-3 border-bottom">
                            <label class="fw-semibold text-muted small">ID</label>
                            <div class="fs-5">@Model.Id</div>
                        </div>

                        <div class="py-3 border-bottom">
                            <label class="fw-semibold text-muted small">Title</label>
                            <div class="fs-5">@Model.Title</div>
                        </div>

                        <div class="py-3 border-bottom">
                            <label class="fw-semibold text-muted small">Description</label>
                            <div>@(string.IsNullOrEmpty(Model.Description) ? "-" : Model.Description)</div>
                        </div>

                        <div class="py-3 border-bottom">
                            <label class="fw-semibold text-muted small">Image URL</label>
                            <div>
                                <a href="@Model.ImageUrl" target="_blank" class="text-primary text-decoration-none">
                                    @Model.ImageUrl <i class="bi bi-box-arrow-up-right ms-1"></i>
                                </a>
                            </div>
                        </div>

                        <div class="py-3 border-bottom">
                            <label class="fw-semibold text-muted small">Link URL</label>
                            <div>
                                @if (!string.IsNullOrEmpty(Model.LinkUrl))
                                {
                                    <a href="@Model.LinkUrl" target="_blank" class="text-primary text-decoration-none">
                                        @Model.LinkUrl <i class="bi bi-box-arrow-up-right ms-1"></i>
                                    </a>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </div>
                        </div>

                        <div class="py-3 border-bottom">
                            <label class="fw-semibold text-muted small">Display Order</label>
                            <div>
                                <span class="badge bg-secondary fs-6">@Model.DisplayOrder</span>
                            </div>
                        </div>

                        <div class="py-3 border-bottom">
                            <label class="fw-semibold text-muted small">Status</label>
                            <div>
                                @if (Model.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </div>
                        </div>

                        <div class="py-3">
                            <label class="fw-semibold text-muted small">Created At</label>
                            <div>@Model.CreatedAt.ToString("MMMM dd, yyyy 'at' HH:mm")</div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card">
                            <div class="card-header bg-light">
                                <h5 class="mb-0">Banner Preview</h5>
                            </div>
                            <div class="card-body text-center">
                                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                {
                                    <img src="@Model.ImageUrl" alt="@Model.Title" class="banner-preview w-100 rounded border">
                                }
                                else
                                {
                                    <div class="banner-preview bg-light rounded border d-flex align-items-center justify-content-center" style="height: 200px;">
                                        <i class="bi bi-image text-muted display-1"></i>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

